{
  "name": "mightycut-library",
  "version": "0.1.0",
  "description": "MightyCut shared component library — the single source of truth for components, treatments, themes, FX, and Zod contracts, consumed by both the render harness and the web UI.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components/*": {
      "bun": "./src/components/*.ts",
      "types": "./src/components/*.ts",
      "import": "./src/components/*.ts"
    },
    "./types/*": {
      "bun": "./src/types/*.ts",
      "types": "./src/types/*.ts",
      "import": "./src/types/*.ts"
    },
    "./pipeline/*": {
      "bun": "./src/pipeline/*.ts",
      "types": "./src/pipeline/*.ts",
      "import": "./src/pipeline/*.ts"
    },
    "./util/*": {
      "bun": "./src/util/*.ts",
      "types": "./src/util/*.ts",
      "import": "./src/util/*.ts"
    },
    "./engine": {
      "import": "./dist/engine/index.js",
      "types": "./dist/types/engine/index.d.ts"
    },
    "./assets/*": "./assets/*"
  },
  "scripts": {
    "gen:fonts": "node scripts/gen-inline-fonts.mjs",
    "pretypecheck": "pnpm gen:fonts",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm gen:fonts",
    "test": "bun test",
    "prebuild:engine": "pnpm gen:fonts",
    "build:engine": "vite build && tsc -p tsconfig.types.json"
  },
  "dependencies": {
    "zod": "4.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.2.0",
    "typescript": "^5.5.4",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^5.0.3"
  }
}
