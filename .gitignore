node_modules/
*.log

# dist/ is generated build output (`pnpm build:engine` → dist/engine + dist/types).
# It is NOT tracked — the consuming app (WebUI) rebuilds it in its own install/build
# step (`pnpm prepare:engine`). Do not commit dist/.
dist/

# Prebuild output: `gen-inline-fonts.mjs` (prebuild:engine / pretest / pretypecheck)
# inlines fonts into these modules before every engine build — block-fonts.generated.ts
# (the core chrome set) plus one <theme>-fonts.generated.ts per theme add-on
# (capsule → Bodoni Moda). Generated, deterministic — do not commit.
# Only src/engine consumes them; the harness never imports the engine path.
src/engine/*-fonts.generated.ts
